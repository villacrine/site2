---
import { getUi, defaultLang, type Lang } from "@/i18n/ui"
import BrevoNewsletterForm from "@/components/forms/BrevoNewsletterForm.astro"

interface Props {
  lang?: Lang
}

const { lang = defaultLang } = Astro.props
const t = await getUi(lang)
---

<section id="prenota" class="bg-cream py-24 lg:py-32">
  <div class="mx-auto max-w-2xl px-6 text-center" data-newsletter-modal-root>
    <p class="mb-4 text-xs font-medium tracking-[0.4em] text-gold uppercase" data-reveal>
      {t["newsletter.kicker"]}
    </p>
    <h2 class="font-serif text-4xl text-balance text-wine lg:text-5xl" data-reveal style="--reveal-delay:100ms">
      {t["newsletter.title"]}
    </h2>
    <p class="mx-auto mt-5 max-w-md text-base font-light leading-relaxed text-pretty text-ink-soft" data-reveal style="--reveal-delay:200ms">
      {t["newsletter.body"]}
    </p>

    <div data-reveal style="--reveal-delay:300ms" class="mt-10">
      <button
        type="button"
        data-newsletter-modal-open
        class="btn-shimmer rounded-full bg-wine px-8 py-3 text-sm font-medium tracking-widest text-cream uppercase hover:bg-wine-deep"
        aria-haspopup="dialog"
        aria-controls="newsletter-modal"
        aria-expanded="false"
      >
        {t["newsletter.cta"]}
      </button>
    </div>

    <div
      id="newsletter-modal"
      hidden
      data-newsletter-modal
      role="dialog"
      aria-modal="true"
      aria-labelledby="newsletter-modal-title"
      class="fixed inset-0 z-[80] flex items-center justify-center p-4 sm:p-6"
    >
      <button
        type="button"
        data-newsletter-modal-overlay
        class="absolute inset-0 bg-wine-deep/75 backdrop-blur-[2px]"
        aria-label="Chiudi finestra iscrizione"
      ></button>

      <div class="relative z-10 w-full max-w-2xl rounded-2xl border border-gold/20 bg-cream p-5 shadow-[0_20px_70px_rgba(0,0,0,0.35)] sm:p-7">
        <div class="mb-5 flex items-start justify-between gap-4">
          <h3 id="newsletter-modal-title" class="font-serif text-2xl text-wine sm:text-3xl">
            {t["newsletter.title"]}
          </h3>
          <button
            type="button"
            data-newsletter-modal-close
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-wine/25 text-wine transition-colors hover:bg-wine hover:text-cream"
            aria-label="Chiudi popup newsletter"
          >
            <span aria-hidden="true">X</span>
          </button>
        </div>

        <div class="max-h-[75vh] overflow-y-auto pr-1">
          <BrevoNewsletterForm lang={lang} className="mx-auto" />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  let newsletterModalAbortController = null

  const bindNewsletterModal = () => {
    newsletterModalAbortController?.abort()
    const controller = new AbortController()
    newsletterModalAbortController = controller
    const { signal } = controller

    const root = document.querySelector("[data-newsletter-modal-root]")
    if (!(root instanceof HTMLElement)) return

    const openButton = root.querySelector("[data-newsletter-modal-open]")
    const modal = root.querySelector("[data-newsletter-modal]")
    const closeButton = root.querySelector("[data-newsletter-modal-close]")
    const overlay = root.querySelector("[data-newsletter-modal-overlay]")
    const submitButton = root.querySelector('#sib-form button[type="submit"]')
    const brevoForm = root.querySelector("#sib-form")

    if (!(openButton instanceof HTMLButtonElement)) return
    if (!(modal instanceof HTMLElement)) return
    if (!(closeButton instanceof HTMLButtonElement)) return
    if (!(overlay instanceof HTMLButtonElement)) return

    let previousFocus = null
    let previousOverflow = ""

    const getFocusableElements = () => {
      const selector = 'a[href], button:not([disabled]), textarea, input, select, [tabindex]:not([tabindex="-1"])'
      return Array.from(modal.querySelectorAll(selector)).filter((el) => {
        if (!(el instanceof HTMLElement)) return false
        return !el.hasAttribute("hidden") && el.offsetParent !== null
      })
    }

    const closeModal = () => {
      modal.hidden = true
      openButton.setAttribute("aria-expanded", "false")
      document.body.style.overflow = previousOverflow
      if (previousFocus instanceof HTMLElement) previousFocus.focus()
    }

    const openModal = () => {
      previousFocus = document.activeElement
      previousOverflow = document.body.style.overflow
      modal.hidden = false
      openButton.setAttribute("aria-expanded", "true")
      document.body.style.overflow = "hidden"

      const focusables = getFocusableElements()
      const first = focusables.find((el) => el instanceof HTMLElement)
      if (first instanceof HTMLElement) first.focus()
    }

    openButton.addEventListener("click", openModal, { signal })
    closeButton.addEventListener("click", closeModal, { signal })
    overlay.addEventListener("click", closeModal, { signal })
    submitButton?.addEventListener("click", closeModal, { signal })
    brevoForm?.addEventListener("submit", closeModal, { signal })

    document.addEventListener(
      "keydown",
      (event) => {
        if (modal.hidden) return

        if (event.key === "Escape") {
          event.preventDefault()
          closeModal()
          return
        }

        if (event.key !== "Tab") return

        const focusables = getFocusableElements()
        if (focusables.length === 0) return

        const first = focusables[0]
        const last = focusables[focusables.length - 1]
        const active = document.activeElement

        if (event.shiftKey && active === first) {
          event.preventDefault()
          last.focus()
        } else if (!event.shiftKey && active === last) {
          event.preventDefault()
          first.focus()
        }
      },
      { signal },
    )

    document.addEventListener(
      "astro:before-swap",
      () => {
        controller.abort()
      },
      { once: true, signal },
    )
  }

  bindNewsletterModal()
  document.addEventListener("astro:after-swap", bindNewsletterModal)
</script>
