---
import { ui, defaultLang } from "@/i18n/ui"
const t = ui[defaultLang]
---

<section class="bg-sand py-24 lg:py-32">
  <div class="mx-auto grid max-w-7xl items-center gap-12 px-6 lg:grid-cols-2 lg:gap-20 lg:px-10">
    <!-- Immagine -->
    <div class="group relative order-2 lg:order-1" data-reveal="left">
      <div class="overflow-hidden rounded-sm shadow-xl">
        <img
          src="/images/cantina-bottaia.png"
          alt="La bottaia della cantina Villa Crine con botti di rovere"
          class="aspect-[4/5] w-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-105"
          loading="lazy"
        />
      </div>
      <div
        class="absolute -bottom-6 -right-6 hidden h-32 w-32 border border-gold/40 transition-transform duration-500 group-hover:-translate-x-2 group-hover:-translate-y-2 lg:block"
        aria-hidden="true"
      >
      </div>
    </div>

    <!-- Testo -->
    <div class="order-1 lg:order-2">
      <p class="mb-4 flex items-center gap-3 text-xs font-medium tracking-[0.4em] text-gold uppercase" data-reveal="right">
        <span class="rule-gold"></span>
        {t["story.kicker"]}
      </p>
      <h2 class="font-serif text-4xl text-balance text-wine lg:text-5xl" data-reveal="right" style="--reveal-delay:120ms">
        {t["story.title"]}
      </h2>
      <p class="mt-6 text-base font-light leading-relaxed text-pretty text-ink-soft" data-reveal="right" style="--reveal-delay:240ms">
        {t["story.body"]}
      </p>
      <a
        href="/chi-siamo"
        data-reveal="right"
        style="--reveal-delay:360ms"
        class="btn-outline-fill mt-8 inline-block rounded-full border border-wine/30 px-7 py-3 text-sm font-medium tracking-widest text-wine uppercase hover:bg-wine hover:text-cream"
      >
        {t["story.cta"]}
      </a>
    </div>
  </div>
</section>
