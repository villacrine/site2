<script define:vars={{ locale, recaptchaHl }}>
  function handleBrevoCaptchaResponse() {
    const event = new Event("captchaChange")
    const captcha = document.getElementById("sib-captcha")
    if (captcha) captcha.dispatchEvent(event)
  }

  window.handleBrevoCaptchaResponse = handleBrevoCaptchaResponse

  window.REQUIRED_CODE_ERROR_MESSAGE = "Scegli un prefisso paese"
  window.LOCALE = locale
  window.EMAIL_INVALID_MESSAGE = window.SMS_INVALID_MESSAGE =
    "Le informazioni fornite non sono valide. Controlla il formato del campo e riprova."
  window.REQUIRED_ERROR_MESSAGE = "Questo campo non puo essere lasciato vuoto."
  window.GENERIC_INVALID_MESSAGE =
    "Le informazioni fornite non sono valide. Controlla il formato del campo e riprova."
  window.INVALID_NUMBER =
    "Le informazioni fornite non sono valide. Controlla il formato del campo e riprova."
  window.INVALID_DATE = "Inserisci una data valida"
  window.REQUIRED_MULTISELECT_MESSAGE = "Seleziona almeno 1 opzione"
  window.translation = {
    common: {
      selectedList: "{quantity} lista selezionata",
      selectedLists: "{quantity} liste selezionate",
      selectedOption: "{quantity} selezionato",
      selectedOptions: "{quantity} selezionati",
    },
  }
  window.AUTOHIDE = false

  const ensureAsset = (selector, create) => {
    if (document.querySelector(selector)) return
    create()
  }

  const loadBrevoAssets = () => {
    ensureAsset('script[data-brevo-main="true"]', () => {
      const script = document.createElement("script")
      script.defer = true
      script.src = "https://sibforms.com/forms/end-form/build/main.js"
      script.dataset.brevoMain = "true"
      document.body.appendChild(script)
    })

    ensureAsset('script[data-brevo-recaptcha="true"]', () => {
      const script = document.createElement("script")
      script.src = `https://www.google.com/recaptcha/api.js?hl=${recaptchaHl}`
      script.dataset.brevoRecaptcha = "true"
      document.body.appendChild(script)
    })
  }

  loadBrevoAssets()
</script>
