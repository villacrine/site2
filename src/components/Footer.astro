---
import { ui, defaultLang } from "@/i18n/ui"
const t = ui[defaultLang]
const year = new Date().getFullYear()

const nav = [
  { href: "/vini", label: t["nav.wines"] },
  { href: "/chi-siamo", label: t["nav.about"] },
  { href: "/territorio", label: t["nav.territory"] },
  { href: "/news", label: t["nav.blog"] },
  { href: "/prenota", label: t["nav.booking"] },
]
---

<footer class="bg-wine-deep text-cream/80">
  <div class="mx-auto grid max-w-7xl gap-12 px-6 py-16 lg:grid-cols-3 lg:px-10">
    <!-- Brand -->
    <div>
      <p class="font-serif text-2xl tracking-[0.2em] uppercase text-cream">Villa Crine</p>
      <p class="mt-4 max-w-xs text-sm font-light leading-relaxed">
        {t["footer.tagline"]}
      </p>
    </div>

    <!-- Navigazione -->
    <nav aria-label="Navigazione footer" class="flex flex-col gap-3">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="link-underline w-fit text-sm font-light text-cream/80 transition-colors hover:text-cream"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- Legale + social -->
    <div class="flex flex-col gap-4">
      <a href="/privacy" class="link-underline w-fit text-sm font-light hover:text-cream">
        {t["footer.privacy"]}
      </a>
      <div class="mt-2 flex items-center gap-4">
        <a
          href="https://instagram.com"
          aria-label="Instagram"
          class="rounded-full border border-cream/20 p-2 transition-colors hover:border-gold hover:text-gold-soft"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
          </svg>
        </a>
        <a
          href="https://facebook.com"
          aria-label="Facebook"
          class="rounded-full border border-cream/20 p-2 transition-colors hover:border-gold hover:text-gold-soft"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M15 3h-2.5A3.5 3.5 0 0 0 9 6.5V9H7v3h2v9h3v-9h2.2l.3-3H12V6.8c0-.5.3-.8.8-.8H15V3Z" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="border-t border-cream/10">
    <div class="mx-auto flex max-w-7xl flex-col gap-2 px-6 py-6 text-xs tracking-wide text-cream/50 sm:flex-row sm:items-center sm:justify-between lg:px-10">
      <p>&copy; {year} Villa Crine. {t["footer.rights"]}</p>
      <p>P.IVA 00000000000 — Valpolicella, Verona, Italia</p>
    </div>
  </div>
</footer>
