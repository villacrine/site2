---
import Layout from "@/layouts/Layout.astro"
import Hero from "@/components/sections/Hero.astro"
import FeaturedWines from "@/components/sections/FeaturedWines.astro"
import Story from "@/components/sections/Story.astro"
import Territory from "@/components/sections/Territory.astro"
import Reviews from "@/components/sections/Reviews.astro"
import News from "@/components/sections/News.astro"
import Newsletter from "@/components/sections/Newsletter.astro"
import { getUi, defaultLang, type Lang } from "@/i18n/ui"

interface Props {
  lang?: Lang
  title?: string
  description?: string
}

const { lang = defaultLang } = Astro.props
const t = await getUi(lang)
const title = Astro.props.title ?? t["site.title"]
const description = Astro.props.description ?? t["site.description"]
---

<Layout title={title} description={description} lang={lang}>
  <Hero lang={lang} />
  <FeaturedWines lang={lang} />
  <Story lang={lang} />
  <Territory lang={lang} />
  <Reviews lang={lang} />
  <News lang={lang} />
  <Newsletter lang={lang} />
</Layout>