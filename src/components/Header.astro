---
import { ui, defaultLang, type Lang } from "@/i18n/ui"

interface Props {
  lang?: Lang
}
const { lang = defaultLang } = Astro.props
const t = ui[defaultLang] // Step 1: solo IT; EN/DE seguiranno

const nav = [
  { href: "/vini", label: t["nav.wines"] },
  { href: "/chi-siamo", label: t["nav.about"] },
  { href: "/territorio", label: t["nav.territory"] },
  { href: "/news", label: t["nav.blog"] },
  { href: "/recensioni", label: t["nav.reviews"] },
]
---

<header
  id="site-header"
  class="site-header fixed top-0 left-0 z-50 w-full"
  data-lang={lang}
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-6 transition-[padding] duration-500 lg:px-10">
    <!-- Logo -->
    <a href="/" class="header-logo group flex flex-col leading-none">
      <span class="font-serif text-2xl tracking-[0.2em] uppercase">Villa Crine</span>
      <span class="mt-1 text-[0.6rem] tracking-[0.4em] uppercase header-sub">
        Valpolicella
      </span>
    </a>

    <!-- Navigazione desktop -->
    <nav class="hidden items-center gap-8 lg:flex" aria-label="Navigazione principale">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="header-link link-underline text-sm font-light tracking-wide transition-colors"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- CTA + lingua -->
    <div class="flex items-center gap-5">
      <div class="header-lang hidden items-center gap-2 text-xs tracking-widest md:flex">
        <a href="/" class="font-medium header-lang-active">IT</a>
        <span aria-hidden="true">·</span>
        <a href="/en" class="transition-colors header-link">EN</a>
        <span aria-hidden="true">·</span>
        <a href="/de" class="transition-colors header-link">DE</a>
      </div>
      <a
        href="/prenota"
        class="header-cta hidden rounded-full border px-5 py-2 text-xs font-medium tracking-widest uppercase transition-colors md:inline-block"
      >
        {t["nav.booking"]}
      </a>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById("site-header")
  const onScroll = () => {
    if (!header) return
    if (window.scrollY > 40) header.classList.add("is-scrolled")
    else header.classList.remove("is-scrolled")
  }
  onScroll()
  window.addEventListener("scroll", onScroll, { passive: true })
  document.addEventListener("astro:after-swap", onScroll)
</script>
