---
import Layout from "@/layouts/Layout.astro"
import { getUi, defaultLang, type Lang } from "@/i18n/ui"
import { getLocalizedNewsArticles } from "@/lib/news"
import NewsCard from "@/components/news/NewsCard.astro"

interface Props {
  lang?: Lang
}

const { lang = defaultLang } = Astro.props
const t = await getUi(lang)
const articles = await getLocalizedNewsArticles(lang)
---

<Layout title={`${t["site.title"]} — ${t["news.title"]}`} description={t["news.body"]} lang={lang}>
  <section class="bg-cream py-28 lg:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-10">
      <div class="mb-16 max-w-3xl">
        <p class="mb-4 text-xs font-medium tracking-[0.4em] text-gold uppercase" data-reveal>
          {t["news.kicker"]}
        </p>
        <h1 class="font-serif text-5xl text-balance text-wine lg:text-6xl" data-reveal style="--reveal-delay:100ms">
          {t["news.title"]}
        </h1>
        <p class="mt-5 max-w-2xl text-base font-light leading-relaxed text-ink-soft" data-reveal style="--reveal-delay:200ms">
          {t["news.body"]}
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {
          articles.length > 0 ? (
            articles.map((article, index) => (
              <div data-reveal style={`--reveal-delay:${index * 120}ms`}>
                <NewsCard article={article} lang={lang} readMoreLabel={t["news.readMore"]} />
              </div>
            ))
          ) : (
            <p class="text-sm text-ink-soft">{t["news.empty"]}</p>
          )
        }
      </div>
    </div>
  </section>
</Layout>