---
import "@/styles/global.css"
import Header from "@/components/Header.astro"
import Footer from "@/components/Footer.astro"
import { getUi, defaultLang, type Lang } from "@/i18n/ui"

interface Props {
  title: string
  description?: string
  lang?: Lang
  image?: string
}

const props = Astro.props as Props
const lang = props.lang ?? defaultLang
const t = await getUi(lang)
const title = props.title ?? t["site.title"]
const description = props.description ?? t["site.description"]
const image = props.image ?? "/images/hero-vigneti.png"

const canonical = new URL(Astro.url.pathname, Astro.site)
const normalizedPath = Astro.url.pathname.replace(/\/+$/, "") || "/"
const isLocaleHome = ["/en", "/de"].includes(normalizedPath)
const isHomePage = normalizedPath === "/" || isLocaleHome
const ogLocale = {
  it: "it_IT",
  en: "en_US",
  de: "de_DE",
}[lang]
---

<!doctype html>
<html lang={lang} class="bg-cream">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Font: Cormorant Garamond (titoli) + Inter (testi) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-cream text-ink antialiased">
    <Header lang={lang} variant={isHomePage ? "overlay" : "solid"} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />

    <script>
      // Scroll reveal: rivela gli elementi [data-reveal] quando entrano nel viewport
      const reveal = () => {
        const els = document.querySelectorAll<HTMLElement>("[data-reveal]")
        if (!("IntersectionObserver" in window) || els.length === 0) {
          els.forEach((el) => el.classList.add("is-visible"))
          return
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible")
                io.unobserve(entry.target)
              }
            })
          },
          { threshold: 0.15, rootMargin: "0px 0px -8% 0px" },
        )
        els.forEach((el) => io.observe(el))
      }

      reveal()
      document.addEventListener("astro:after-swap", reveal)
    </script>
  </body>
</html>
