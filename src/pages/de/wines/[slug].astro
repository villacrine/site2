---
import WineArticlePage from "@/components/wines/WineArticlePage.astro"
import { getLocalizedWine, getWineStaticPaths } from "@/lib/wines"

export const getStaticPaths = () => getWineStaticPaths("de")

const { slug } = Astro.params
const wine = await getLocalizedWine("de", slug as string)

if (!wine) {
  return Astro.redirect("/de/wines")
}
---

<WineArticlePage lang="de" wine={wine} />
